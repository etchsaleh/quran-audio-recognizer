ENV=dev

# API / server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=12

# Quran data (cached locally after first boot)
QURAN_DATA_PATH=
QURAN_DATA_URL=https://raw.githubusercontent.com/amrayn/quran-text/master/quran-full-tashkeel.json

# Whisper (faster-whisper)
# Quran-specific model improves recitation transcription; use base for generic Arabic
WHISPER_MODEL=OdyAsh/faster-whisper-base-ar-quran
WHISPER_LANGUAGE=ar
# int8 works on all CPUs; float16 only where supported (e.g. some GPUs)
WHISPER_COMPUTE_TYPE=int8
PRELOAD_WHISPER=false

# Matching (balanced: fewer wrong matches, fewer false negatives)
MIN_CONFIDENCE=0.45

