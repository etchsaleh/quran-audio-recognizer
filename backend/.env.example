ENV=dev

# API / server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=12

# Quran data (cached locally after first boot)
QURAN_DATA_PATH=
QURAN_DATA_URL=https://raw.githubusercontent.com/amrayn/quran-text/master/quran-full-tashkeel.json

# Whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=ar
PRELOAD_WHISPER=false

# Matching
MIN_CONFIDENCE=0.35

